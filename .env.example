# PostgreSQL connection (Railway Postgres plugin sets DATABASE_URL automatically)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/voice?schema=public"

# Upstash Redis (optional — if unset, the app uses an in-memory cache fallback)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Public base URL (used for metadata / absolute links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Implementador del buscador (DS SAFETY + catálogo Dräger)
NEXT_PUBLIC_PARTNER_NAME="DS SAFETY"
NEXT_PUBLIC_PARTNER_TAGLINE="Soluciones de seguridad y protección respiratoria Dräger"
NEXT_PUBLIC_CATALOG_LABEL="Catálogo digital Dräger — DS SAFETY"
# PDF del catálogo (por defecto el archivo en public/catalogo-drager-ds-safety.pdf)
NEXT_PUBLIC_CATALOG_URL="/catalogo-drager-ds-safety.pdf"
NEXT_PUBLIC_PARTNER_WEBSITE_URL=""

# Desarrollador de la app (enlace «Desarrollado por Dorvia» en el pie)
NEXT_PUBLIC_DEVELOPER_URL="https://www.dorvia.com.ar/"
