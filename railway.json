{
  "$schema": "https://schema.up.railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "chmod +x scripts/railway-build.sh && ./scripts/railway-build.sh"
  },
  "deploy": {
    "startCommand": "chmod +x scripts/railway-start.sh && ./scripts/railway-start.sh",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
